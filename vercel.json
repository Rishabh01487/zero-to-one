{
  "buildCommand": "npm run build",
  "outputDirectory": "frontend/dist",
  "experimentalServices": {
    "frontend": {
      "root": "frontend",
      "routePrefix": "/",
      "framework": "vite"
    },
    "backend": {
      "root": "backend",
      "entrypoint": "server.js",
      "routePrefix": "/_/backend"
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/_/backend/api/$1" }
  ]
}
